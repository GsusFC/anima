{
  "name": "animagen",
  "version": "1.0.0",
  "description": "Professional animation creation tool",
  "main": "backend/index.js",
  "scripts": {
    "start": "node backend/index.js",
    "build": "cd frontend && npm install && npm run build && mkdir -p ../backend/public && cp -r dist/* ../backend/public/",
    "install": "cd backend && npm install",
    "postinstall": "npm run build",
    "dev": "concurrently \"cd backend && npm run dev\" \"cd frontend && npm run dev\"",
    "test": "cd backend && npm test"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "fluent-ffmpeg": "^2.1.2",
    "socket.io": "^4.8.1"
  },
  "author": "GsusFC",
  "license": "MIT"
}
